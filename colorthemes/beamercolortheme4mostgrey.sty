% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

% Colors from http://web.mit.edu/graphicidentity/colors.html
\definecolor{mitred}{cmyk}{0.24, 1.0, 0.78, 0.17}
\definecolor{mitdarkgray}{cmyk}{0.48, 0.39, 0.39, 0.04}
\definecolor{mitlightgray}{cmyk}{0.24, 0.20, 0.20, 0.0}

% Extra colors
\definecolor{lightgray}{RGB}{240, 240, 240}
\definecolor{lightorange}{RGB}{255, 245, 242}

\definecolor{blue}{RGB}{64, 115, 158}
\definecolor{darkblue}{RGB}{39, 60, 117}
\definecolor{lightblue}{RGB}{232, 244, 255}

\definecolor{vista_blue}{RGB}{18, 62, 156}
\definecolor{vista_grey}{RGB}{240, 239, 233}
\definecolor{vista_light_blue}{RGB}{123, 197, 229}
\definecolor{4most_dark_grey}{RGB}{35, 40, 43}
\definecolor{4most_orange}{RGB}{236, 107, 34}
\definecolor{4most_red}{RGB}{210, 29, 44}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=mitred}

% Headline
\setbeamercolor{headline}{fg=black,bg=lightgray}

% Block
\setbeamercolor{block title}{fg=vista_blue,bg=white}
\setbeamercolor{block separator}{bg=black}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block title alerted}{fg=vista_blue,bg=lightblue}
\setbeamercolor{block separator alerted}{bg=black}
\setbeamercolor{block body alerted}{fg=black,bg=lightblue}

% Example Block
\setbeamercolor{block title example}{fg=vista_blue,bg=lightblue}
\setbeamercolor{block separator example}{bg=black}
\setbeamercolor{block body example}{fg=black,bg=lightblue}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=mitred}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
